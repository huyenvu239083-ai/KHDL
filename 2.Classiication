import pandas as pd
from sklearn.linear_model import LogisticRegression

df = pd.read_csv("student-mat.csv")

# Tạo nhãn pass/fail
df['Pass'] = df['G3'].apply(lambda x: 1 if x >= 10 else 0)

X = df[['G1', 'G2']]
y = df['Pass']

model = LogisticRegression()

model.fit(X, y)

print("Dự đoán Pass/Fail:")
print(model.predict(X[:10]))
